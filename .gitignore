node_modules/
.pnp
.pnp.js

# 测试
coverage/

# Next.js
.next/
out/
build/

# 生产
dist/

# 环境变量（包含密钥，绝对不能提交）
.env*.local
.env

# 调试
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 系统
.DS_Store
*.pem
Thumbs.db

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# Vercel
.vercel

# ResearchKit 运行时产物（不应进仓库）
.researchkit-memory.json
.researchkit-output/
.researchkit-data/

# 回归测试报告产物（测试时生成，不应进仓库）
scripts/reports/*.json
scripts/reports/*.md
!scripts/reports/.gitkeep

# TypeScript 增量编译缓存
*.tsbuildinfo

# Release artifacts — 大文件用 LFS，普通文件按大小决定
# 截图 PNG（< 1 MB）正常提交；视频 MP4（> 50 MB）建议 LFS 或外部链接
releases/demo-video/*.mp4
!releases/demo-video/.gitkeep
!releases/demo-video/README.md

# 个人建议 / 计划草稿（本地笔记，不上传）
自定义*.txt
v2.1方案优化建议.txt
其他功能.txt
